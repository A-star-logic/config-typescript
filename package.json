{
  "name": "@ansearch/config",
  "version": "3.0.0",
  "private": false,
  "publishConfig": {
    "access": "public"
  },
  "packageManager": "yarn@4.13.0",
  "description": "The various configs used to code in Typescript at A* Logic",
  "homepage": "https://github.com/A-star-logic/config-typescript",
  "repository": {
    "type": "git",
    "url": "https://github.com/A-star-logic/config-typescript.git"
  },
  "bugs": {
    "url": "https://github.com/A-star-logic/config-typescript/issues"
  },
  "license": "MIT",
  "author": "A* Logic (https://astarlogic.com)",
  "devDependencies": {
    "@swc/core": "^1.15.0",
    "@types/eslint-plugin-security": "^3.0.0",
    "@types/node": "^24.10.0",
    "prettier": "^3.6.2",
    "tsup": "^8.5.0",
    "typescript": "5.9.3"
  },
  "exports": {
    "./compilers/*": {
      "types": "./compilers/*",
      "default": "./compilers/*"
    },
    "./linters/*": {
      "types": "./linters/*",
      "default": "./linters/*"
    }
  },
  "bin": {
    "npmjs-version-verify": "./bin/version-check.js"
  },
  "scripts": {
    "build": "tsc",
    "verify": "node ./bin/version-check.js \"$(npm view @ansearch/config version)\" ../package.json"
  },
  "type": "module",
  "peerDependencies": {
    "@eslint-community/eslint-plugin-eslint-comments": "*",
    "@eslint/compat": "*",
    "@eslint/js": "*",
    "@typescript-eslint/parser": "*",
    "eslint": "*",
    "eslint-config-prettier": "*",
    "eslint-import-resolver-typescript": "*",
    "eslint-plugin-drizzle": "*",
    "eslint-plugin-fp": "*",
    "eslint-plugin-import-x": "*",
    "eslint-plugin-jsdoc": "*",
    "eslint-plugin-perfectionist": "*",
    "eslint-plugin-prettier": "*",
    "eslint-plugin-regexp": "*",
    "eslint-plugin-security": "*",
    "eslint-plugin-sonarjs": "*",
    "eslint-plugin-unicorn": "*",
    "eslint-plugin-vue": "*",
    "prettier": "*",
    "typescript": "*",
    "typescript-eslint": "*",
    "vue-eslint-parser": "*"
  }
}
